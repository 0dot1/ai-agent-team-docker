# AI Agent Team - Environment Variables
# i7 Team Configuration
# ⚠️  IMPORTANT: Copy this file to .env and fill in your REAL values
#     NEVER commit .env to GitHub!

# ============================================================
# AI Model API Keys (Required)
# ============================================================

# Anthropic Claude - Primary for PM/Dev
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI GPT-4 - For Security/Ops
OPENAI_API_KEY=sk-your-openai-key-here

# Kimi (Optional)
KIMI_API_KEY=your-kimi-key-optional

# ============================================================
# Telegram Bot Tokens (i7 Team)
# Get from @BotFather: https://t.me/BotFather
# Format: 123456789:ABCdefGHIjklMNOpqrSTUvwxyz
# ============================================================

# 项目经理 i10
TELEGRAM_BOT_TOKEN_PM=your-pm-bot-token-here

# 设计师 i9
TELEGRAM_BOT_TOKEN_UI=your-ui-bot-token-here

# 大前端 i8
TELEGRAM_BOT_TOKEN_FRONTEND=your-frontend-bot-token-here

# 全栈大佬 i6
TELEGRAM_BOT_TOKEN_BACKEND=your-backend-bot-token-here

# App小研 i5
TELEGRAM_BOT_TOKEN_APP=your-app-bot-token-here

# 安全大哥 i3
TELEGRAM_BOT_TOKEN_SECURITY=your-security-bot-token-here

# 运营大师 i1
TELEGRAM_BOT_TOKEN_OPS=your-ops-bot-token-here

# ============================================================
# Team Configuration
# ============================================================
